# Application identity and logging
APP_NAME=mini-llm-serving-platform
ENV=local
LOG_LEVEL=INFO

# Client-to-Gateway authentication.
# Replace these before exposing the Gateway outside local development.
API_KEYS=dev-key,team-a-key
# Per-API-key request and estimated token limiting.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPM=60
RATE_LIMIT_TPM=60000
RATE_LIMIT_CONCURRENT_REQUESTS=20
RATE_LIMIT_DEFAULT_COMPLETION_TOKENS=256
REDIS_URL=redis://localhost:6379/0

# Request/input safety limits.
MAX_REQUEST_BODY_BYTES=1048576
MAX_CHAT_MESSAGES=64
MAX_CHAT_MESSAGE_CHARS=16000
MAX_CHAT_TOTAL_MESSAGE_CHARS=64000

# Local Gateway process binding.
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080

# Gateway backend selection.
# Use BACKEND_TYPE=mock for the local mock backend.
# Use BACKEND_TYPE=vllm when routing to an OpenAI-compatible vLLM server.
BACKEND_TYPE=mock
MOCK_BASE_URL=http://localhost:9000/v1
VLLM_BASE_URL=http://localhost:8000/v1

# Gateway-to-vLLM authentication.
# This must match the --api-key passed to vLLM when BACKEND_TYPE=vllm.
VLLM_API_KEY=local-vllm-key

# vLLM container/runtime settings used by Docker Compose GPU mode and K8s/Helm.
VLLM_MODEL=Qwen/Qwen2.5-1.5B-Instruct
VLLM_IMAGE_TAG=latest
VLLM_DTYPE=auto

# Required only for gated Hugging Face models.
HUGGING_FACE_HUB_TOKEN=

# Upstream request timeouts.
BACKEND_TIMEOUT_SECONDS=120
STREAMING_TIMEOUT_SECONDS=300

# Client-facing model names.
# The Gateway rewrites aliases to backend model ids before forwarding requests.
DEFAULT_MODEL=mock
MODEL_ALIASES_JSON={"mock":"mock","qwen-small":"Qwen/Qwen2.5-1.5B-Instruct"}

# Prometheus metrics endpoint.
METRICS_ENABLED=true
